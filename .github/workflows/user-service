name: User Service CI

on:
  push:
    paths:
      - 'services/user-service/**'

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3

      - name: Build Image
        run: |
          docker build -t ${{ secrets.DOCKER_USER }}/user-service:${{ github.sha }} ./services/user-service

      - name: Login DockerHub
        run: echo "${{ secrets.DOCKER_PASS }}" | docker login -u "${{ secrets.DOCKER_USER }}" --password-stdin

      - name: Push Image
        run: docker push ${{ secrets.DOCKER_USER }}/user-service:${{ github.sha }}
